# =============================================================================
# Docube Blockchain — Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and modify as needed:
#   cp .env.example .env
#
# All values below are defaults — only override what you need to change.
# =============================================================================

# --- CouchDB (state database for Fabric peers) ---
COUCHDB_USER=admin
COUCHDB_PASSWORD=adminpw

# --- Kafka (shared via horob1_docub network) ---
KAFKA_BROKERS=kafka:7094
KAFKA_GROUP_ID=blockchain-service-group
KAFKA_SASL_ENABLED=true
KAFKA_SASL_USERNAME=horob1
KAFKA_SASL_PASSWORD=2410

# --- Redis (shared via horob1_docub network) ---
REDIS_ADDR=redis:6379
REDIS_PASSWORD=2410
REDIS_DB=1
REDIS_TTL=900

# --- Eureka Service Discovery ---
# Docker Desktop (Windows/Mac): host.docker.internal works out of the box
# Linux: extra_hosts in compose maps host.docker.internal to host-gateway
EUREKA_SERVER_URL=http://host.docker.internal:9000/eureka

# IP that blockchain-service registers with Eureka.
# Use host.docker.internal so other services on the host can reach it.
# On production server, set this to the server's actual IP.
EUREKA_INSTANCE_IP=host.docker.internal

# --- Port mapping ---
# Host port for blockchain-service (container always listens on 8080)
BLOCKCHAIN_SERVICE_PORT=8082
