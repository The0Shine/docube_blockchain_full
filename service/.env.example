# =============================================================================
# Docube Blockchain Service — Environment Variables (native/WSL mode)
# =============================================================================
# Copy to .env and modify as needed. These are used when running the Go binary
# directly (not via Docker). Docker mode uses docker-compose environment instead.
# =============================================================================

# --- Application ---
APP_NAME=fabric-gateway-service
APP_PORT=8081
ENV=dev

# --- Eureka Service Discovery ---
EUREKA_SERVER_URL=http://localhost:9000/eureka
EUREKA_HEARTBEAT_INTERVAL=30

# --- Kafka ---
KAFKA_BROKERS=localhost:7092
KAFKA_GROUP_ID=blockchain-service-group
KAFKA_SASL_ENABLED=true
KAFKA_SASL_USERNAME=horob1
KAFKA_SASL_PASSWORD=2410

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=2410
REDIS_DB=1
REDIS_TTL=900

# --- Fabric SDK ---
FABRIC_CHANNEL_NAME=docubechannel
FABRIC_CHAINCODE_NAME=document_nft_cc
FABRIC_MSP_ID=AdminOrgMSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_GATEWAY_PEER=peer0.adminorg.docube.com
FABRIC_CRYPTO_PATH=../network/organizations/peerOrganizations/adminorg.docube.com

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
