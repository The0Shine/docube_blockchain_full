# Environment Variables for Docube Blockchain Service
# Copy this file to .env and modify as needed

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=fabric-gateway-service
APP_PORT=8080
ENV=dev

# =============================================================================
# EUREKA SERVICE DISCOVERY
# =============================================================================
EUREKA_SERVER_URL=http://localhost:8761/eureka
EUREKA_HEARTBEAT_INTERVAL=30

# =============================================================================
# FABRIC SDK (Future - Not Implemented Yet)
# =============================================================================
# FABRIC_CONNECTION_PROFILE=./config/connection-profile.yaml
# FABRIC_CHANNEL=docubechannel
# FABRIC_CHAINCODE=document_nft_cc
# FABRIC_ORG_MSP=AdminOrgMSP
# FABRIC_WALLET_PATH=./wallet

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
